# Server
PORT=3002
FRONTEND_URL=http://localhost:5173

# ElevenLabs (set via Settings page or here)
ELEVENLABS_API_KEY=

# Owner auth (simple token for now)
AUTH_TOKEN=change-me-to-a-secure-random-string


# Pin the WhatsApp Web build whatsapp-web.js loads. Bump this when WhatsApp
# ships an update that breaks message sync (symptom: "waitForChatLoading"
# crash, chats stop updating). Pick any filename from
# https://github.com/wppconnect-team/wa-version/tree/main/html (omit .html).
WA_WEB_VERSION=2.3000.1023223821
